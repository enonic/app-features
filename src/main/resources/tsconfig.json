{
  "include": [
    "**/*.ts"
  ],
  "exclude": [
    "assets/**/*.*"
  ],
  "compilerOptions": {
    "paths": {
      "/lib/xp/*": [
        "../../../node_modules/@enonic-types/lib-*"
      ],
      "/lib/enonic/asset": [
        "../../../node_modules/@enonic-types/lib-asset"
      ],
      "/lib/enonic/cors": [
        "./types/cors"
      ],
      "/lib/thymeleaf": [
        "./types/thymeleaf"
      ],
      "/lib/http-client": [
        "./types/http-client"
      ],
      "/lib/text-encoding": [
        "./types/text-encoding"
      ],
      "/lib/mustache": [
        "./types/mustache"
      ],
      "/lib/xslt": [
        "./types/xslt"
      "/lib/markdown": [
        "./types/markdown"
      ],
      "/*": [
        "./*"
      ]
    },
    "skipLibCheck": true,
    "types": [
      "@enonic-types/global"
    ]
  }
}
